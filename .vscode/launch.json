{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(lldb) Debug Project",
            "type": "lldb",
            "request": "launch",
            // "preLaunchTask": "build debug executable",
            "program": "${workspaceFolder}/build/eMgine",
            "stdio": [
                "${workspaceFolder}/build/sim_user_input.txt", // redirect stdin
                null, // redirect stdout
                null // redirect stderr
